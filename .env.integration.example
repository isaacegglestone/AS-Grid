# .env.integration.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.integration and fill in your Bitunix Futures API
# credentials before running the integration test suite.
#
# .env.integration is gitignored — never commit real credentials.
#
# How to run the suite:
#   pytest -m integration tests/integration/ -v -s
#
# Account requirements:
#   - Bitunix Futures account (can be mainnet or testnet if available)
#   - At least $100 USDT free margin
#   - API key with futures trading permissions (read + trade)
#   - No open positions or orders on XRP/USDT when starting
#
# Cost estimate:
#   Full suite ≈ $0.05 in maker/taker fees (1-XRP market orders at ~$2.50)
# ─────────────────────────────────────────────────────────────────────────────

BITUNIX_INT_API_KEY=your_api_key_here
BITUNIX_INT_SECRET_KEY=your_secret_key_here
