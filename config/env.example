# 交易所配置
EXCHANGE=gate  # 交易所选择: gate 或 binance
CONTRACT_TYPE=USDT  # 合约类型: USDT 或 USDC (仅币安需要)

# Gate.io API 配置

# Gate.io API 配置
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here

# Binance API 配置 (当 EXCHANGE=binance 时使用)
# API_KEY=your_binance_api_key_here
# API_SECRET=your_binance_api_secret_here

# 交易配置
COIN_NAME=X
GRID_SPACING=0.004
INITIAL_QUANTITY=1
LEVERAGE=20

# Telegram 通知配置 (可选)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
ENABLE_NOTIFICATIONS=true
NOTIFICATION_INTERVAL=3600 

# ---------------------------------------------------------------------------
# Regime filter + BTBW spacing
# ---------------------------------------------------------------------------
# REGIME_EMA_PERIOD=175
# REGIME_HYSTERESIS_PCT=0.00
# BULL_SPACING=0.010
# BEAR_SPACING=0.015

# ---------------------------------------------------------------------------
# Grid behaviour switches
# ---------------------------------------------------------------------------
# GRID_LONG_ONLY=false            # suppress ALL short grid entries
# REGIME_SHORT_GATE=false         # shorts only in bear regime (below regime EMA)

# ---------------------------------------------------------------------------
# Equity-proportional sizing (v17)
# ---------------------------------------------------------------------------
# ORDER_VALUE_PCT=0.0             # 0=fixed INITIAL_QUANTITY; >0 = % of equity per leg
# ORDER_VALUE_MIN=10.0            # USDT floor per leg (prevents dust orders)

# ---------------------------------------------------------------------------
# Volume-adaptive spacing — VAS (v18)
# ---------------------------------------------------------------------------
# VAS_ENABLED=false
# VAS_FLOOR=0.008                 # min spacing
# VAS_CEIL=0.020                  # max spacing
# VAS_PERIOD=40                   # EMA window for ATR-fraction baseline

# ---------------------------------------------------------------------------
# Circuit breakers — crash + surge (v37)
# ---------------------------------------------------------------------------
# CRASH_CB=false
# CRASH_CB_DROP_PCT=0.10          # 10% drop triggers
# CRASH_CB_LOOKBACK_MINS=120      # 2h lookback
# CRASH_CB_HALT_MINS=720          # 12h halt

# SURGE_CB=false
# SURGE_CB_RISE_PCT=0.10          # 10% rise triggers
# SURGE_CB_LOOKBACK_MINS=120      # 2h lookback
# SURGE_CB_HALT_MINS=720          # 12h halt

# ---------------------------------------------------------------------------
# Drawdown halt (v37)
# ---------------------------------------------------------------------------
# DD_HALT=false
# DD_HALT_MAX_DRAWDOWN=0.30       # 30% drawdown triggers flatten-all + pause
# DD_HALT_MINS=5760               # 4-day halt

# ---------------------------------------------------------------------------
# Rally gate (v40) — suppress shorts during parabolic rallies
# ---------------------------------------------------------------------------
# RALLY_GATE=false
# RALLY_GATE_WINDOW=2880          # fast tier: 2 days (1min candles)
# RALLY_GATE_ENTRY_PCT=0.30       # 30% rise triggers fast tier
# RALLY_GATE_EXIT_PCT=0.10        # clears when all tiers < 10%
# RALLY_GATE_WINDOW_MED=10080     # 1 week
# RALLY_GATE_ENTRY_PCT_MED=0.50   # 50% rise triggers medium tier
# RALLY_GATE_WINDOW_SLOW=43200    # 1 month
# RALLY_GATE_ENTRY_PCT_SLOW=1.00  # 100% (2x) triggers slow tier

# ---------------------------------------------------------------------------
# Grid vol scale (v12) — shrink order qty when volume >> average
# ---------------------------------------------------------------------------
# GRID_VOL_SCALE=false
# GRID_VOL_FLOOR=0.35             # min multiplier (35% of normal)